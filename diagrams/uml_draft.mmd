classDiagram
    class Owner {
        +String name
        +List pets
        +add_pet(pet)
        +get_all_tasks()
    }

    class Pet {
        +String name
        +String species
        +List tasks
        +add_task(task)
    }

    class Task {
        +String title
        +int duration
        +String priority
        +String time
        +String frequency
        +bool completed
        +mark_complete()
    }

    class Scheduler {
        +Owner owner
        +sort_by_priority()
        +get_daily_plan()
        +detect_conflicts()
        +filter_by_pet()
    }

    Owner "1" --> "many" Pet : has
    Pet "1" --> "many" Task : has
    Scheduler "1" --> "1" Owner : manages